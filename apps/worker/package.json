{
  "name": "@quantflow/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "pnpm --filter @quantflow/api db:generate && tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "typecheck": "pnpm --filter @quantflow/api db:generate && tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@nestjs/common": "11.1.27",
    "@nestjs/core": "11.1.27",
    "@prisma/adapter-pg": "7.1.0",
    "@prisma/client": "7.1.0",
    "pg": "8.16.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@types/node": "26.0.0",
    "@types/pg": "8.16.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
