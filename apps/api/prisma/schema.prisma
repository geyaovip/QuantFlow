generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  active
  disabled
  risk_watch
  deleting

  @@map("user_status")
}

enum AdminUserStatus {
  active
  disabled

  @@map("admin_user_status")
}

enum AuthPortal {
  user
  admin

  @@map("auth_portal")
}

enum AuthSessionAudience {
  user
  admin

  @@map("auth_session_audience")
}

enum SecurityEventType {
  auth_otp_requested
  auth_otp_sent
  auth_otp_send_failed
  auth_otp_verified
  auth_otp_failed
  auth_session_created
  auth_logout

  @@map("security_event_type")
}

enum MembershipTier {
  free
  pro
  premium

  @@map("membership_tier")
}

enum StrategyStatus {
  draft
  pending_review
  active
  paused
  risk_watch
  delisted

  @@map("strategy_status")
}

enum StrategyType {
  spot
  grid
  dca
  trend
  swing

  @@map("strategy_type")
}

enum RiskLevel {
  low
  medium
  high
  critical

  @@map("risk_level")
}

enum StrategyMetricPeriod {
  seven_days
  thirty_days
  ninety_days
  all_time

  @@map("strategy_metric_period")
}

enum SignalDirection {
  buy
  sell
  watch

  @@map("signal_direction")
}

enum SignalStatus {
  active
  expired
  cancelled
  strategy_paused
  risk_blocked

  @@map("signal_status")
}

enum StrategySubscriptionStatus {
  active
  cancelled

  @@map("strategy_subscription_status")
}

enum MembershipPlanStatus {
  active
  inactive

  @@map("membership_plan_status")
}

enum UserSubscriptionStatus {
  active
  expired
  cancelled

  @@map("user_subscription_status")
}

enum UserSubscriptionSource {
  manual
  invite
  test

  @@map("user_subscription_source")
}

enum PaperAccountStatus {
  running
  paused
  ended
  data_error
  strategy_paused

  @@map("paper_account_status")
}

enum PaperOrderSide {
  buy
  sell

  @@map("paper_order_side")
}

enum PaperOrderType {
  market

  @@map("paper_order_type")
}

enum PaperOrderStatus {
  pending
  filled
  cancelled
  rejected

  @@map("paper_order_status")
}

enum PaperPositionStatus {
  open
  closed

  @@map("paper_position_status")
}

model User {
  id              String                     @id @default(uuid()) @db.Uuid
  emailNormalized String                     @unique @map("email_normalized")
  email           String
  status          UserStatus                 @default(active)
  lastLoginAt     DateTime?                  @map("last_login_at") @db.Timestamptz(6)
  createdAt       DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  securityEvents  UserSecurityEvent[]
  subscriptions   UserStrategySubscription[]
  membershipSubs  UserSubscription[]
  paperAccounts   PaperAccount[]

  @@map("users")
}

model AdminUser {
  id              String          @id @default(uuid()) @db.Uuid
  emailNormalized String          @unique @map("email_normalized")
  email           String
  status          AdminUserStatus @default(active)
  lastLoginAt     DateTime?       @map("last_login_at") @db.Timestamptz(6)
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  auditLogs       AdminAuditLog[] @relation("AdminAuditActor")

  @@map("admin_users")
}

model AuthEmailChallenge {
  id              String     @id @default(uuid()) @db.Uuid
  emailNormalized String     @map("email_normalized")
  emailHash       String     @map("email_hash")
  portal          AuthPortal
  codeHash        String     @map("code_hash")
  expiresAt       DateTime   @map("expires_at") @db.Timestamptz(6)
  usedAt          DateTime?  @map("used_at") @db.Timestamptz(6)
  failedAttempts  Int        @default(0) @map("failed_attempts")
  requestedIp     String?    @map("requested_ip")
  requestedUa     String?    @map("requested_ua")
  resendMessageId String?    @map("resend_message_id")
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([emailNormalized, portal, createdAt(sort: Desc), id(sort: Desc)], map: "idx_auth_email_challenges_lookup")
  @@index([expiresAt], map: "idx_auth_email_challenges_expires")
  @@map("auth_email_challenges")
}

model AuthSession {
  id         String              @id @default(uuid()) @db.Uuid
  subjectId  String              @map("subject_id") @db.Uuid
  audience   AuthSessionAudience
  tokenHash  String              @unique @map("token_hash")
  expiresAt  DateTime            @map("expires_at") @db.Timestamptz(6)
  revokedAt  DateTime?           @map("revoked_at") @db.Timestamptz(6)
  lastSeenAt DateTime?           @map("last_seen_at") @db.Timestamptz(6)
  createdIp  String?             @map("created_ip")
  createdUa  String?             @map("created_ua")
  createdAt  DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([subjectId, audience, revokedAt], map: "idx_auth_sessions_subject")
  @@index([expiresAt], map: "idx_auth_sessions_expires")
  @@map("auth_sessions")
}

model UserSecurityEvent {
  id              String            @id @default(uuid()) @db.Uuid
  userId          String?           @map("user_id") @db.Uuid
  user            User?             @relation(fields: [userId], references: [id])
  emailNormalized String?           @map("email_normalized")
  eventType       SecurityEventType @map("event_type")
  portal          AuthPortal?
  ip              String?
  userAgent       String?           @map("user_agent")
  metadata        Json?
  occurredAt      DateTime          @default(now()) @map("occurred_at") @db.Timestamptz(6)

  @@index([userId, occurredAt(sort: Desc), id(sort: Desc)], map: "idx_user_security_events_user")
  @@index([emailNormalized, occurredAt(sort: Desc), id(sort: Desc)], map: "idx_user_security_events_email")
  @@map("user_security_events")
}

model Strategy {
  id                   String                     @id @default(uuid()) @db.Uuid
  slug                 String                     @unique
  name                 String
  summary              String
  type                 StrategyType
  riskLevel            RiskLevel                  @map("risk_level")
  status               StrategyStatus             @default(draft)
  requiredTier         MembershipTier             @default(free) @map("required_tier")
  supportsPaperTrading Boolean                    @default(true) @map("supports_paper_trading")
  publishedAt          DateTime?                  @map("published_at") @db.Timestamptz(6)
  deletedAt            DateTime?                  @map("deleted_at") @db.Timestamptz(6)
  createdAt            DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  versions             StrategyVersion[]
  metrics              StrategyMetric[]
  signals              StrategySignal[]
  subscriptions        UserStrategySubscription[]
  auditLogs            AdminAuditLog[]
  paperAccounts        PaperAccount[]

  @@index([status, riskLevel, publishedAt(sort: Desc), id], map: "idx_strategies_list")
  @@map("strategies")
}

model StrategyVersion {
  id               String           @id @default(uuid()) @db.Uuid
  strategyId       String           @map("strategy_id") @db.Uuid
  strategy         Strategy         @relation(fields: [strategyId], references: [id])
  version          Int
  symbols          String[]
  logic            String
  suitableMarket   String           @map("suitable_market")
  unsuitableMarket String           @map("unsuitable_market")
  positionSizing   String           @map("position_sizing")
  stopLossLogic    String           @map("stop_loss_logic")
  takeProfitLogic  String           @map("take_profit_logic")
  failureModes     String           @map("failure_modes")
  dataSource       String           @map("data_source")
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  metrics          StrategyMetric[]
  signals          StrategySignal[]
  paperAccounts    PaperAccount[]

  @@unique([strategyId, version], map: "uniq_strategy_versions_version")
  @@index([strategyId, version(sort: Desc)], map: "idx_strategy_versions_latest")
  @@map("strategy_versions")
}

model StrategyMetric {
  id                String               @id @default(uuid()) @db.Uuid
  strategyId        String               @map("strategy_id") @db.Uuid
  strategy          Strategy             @relation(fields: [strategyId], references: [id])
  strategyVersionId String               @map("strategy_version_id") @db.Uuid
  strategyVersion   StrategyVersion      @relation(fields: [strategyVersionId], references: [id])
  period            StrategyMetricPeriod
  returnRate        Decimal              @map("return_rate") @db.Decimal(18, 8)
  maxDrawdown       Decimal              @map("max_drawdown") @db.Decimal(18, 8)
  winRate           Decimal              @map("win_rate") @db.Decimal(18, 8)
  profitLossRatio   Decimal              @map("profit_loss_ratio") @db.Decimal(18, 8)
  tradeCount        Int                  @map("trade_count")
  sampleSize        Int                  @map("sample_size")
  dataSource        String               @map("data_source")
  calculatedAt      DateTime             @map("calculated_at") @db.Timestamptz(6)

  @@unique([strategyVersionId, period, dataSource, calculatedAt], map: "uniq_strategy_metrics_snapshot")
  @@index([strategyId, period, calculatedAt(sort: Desc)], map: "idx_strategy_metrics_latest")
  @@map("strategy_metrics")
}

model StrategySignal {
  id                   String          @id @default(uuid()) @db.Uuid
  strategyId           String          @map("strategy_id") @db.Uuid
  strategy             Strategy        @relation(fields: [strategyId], references: [id])
  strategyVersionId    String          @map("strategy_version_id") @db.Uuid
  strategyVersion      StrategyVersion @relation(fields: [strategyVersionId], references: [id])
  symbol               String
  direction            SignalDirection
  triggerPrice         Decimal         @map("trigger_price") @db.Decimal(28, 8)
  currentPriceSnapshot Decimal         @map("current_price_snapshot") @db.Decimal(28, 8)
  suggestedPositionPct Decimal         @map("suggested_position_pct") @db.Decimal(18, 8)
  stopLossPrice        Decimal         @map("stop_loss_price") @db.Decimal(28, 8)
  takeProfitPrice      Decimal         @map("take_profit_price") @db.Decimal(28, 8)
  rationale            String
  status               SignalStatus    @default(active)
  riskLevel            RiskLevel       @map("risk_level")
  generatedAt          DateTime        @map("generated_at") @db.Timestamptz(6)
  validUntil           DateTime        @map("valid_until") @db.Timestamptz(6)
  createdAt            DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  paperOrders          PaperOrder[]

  @@index([status, generatedAt(sort: Desc), id], map: "idx_strategy_signals_list")
  @@index([strategyId, status, generatedAt(sort: Desc), id], map: "idx_strategy_signals_strategy")
  @@map("strategy_signals")
}

model UserStrategySubscription {
  id           String                     @id @default(uuid()) @db.Uuid
  userId       String                     @map("user_id") @db.Uuid
  user         User                       @relation(fields: [userId], references: [id])
  strategyId   String                     @map("strategy_id") @db.Uuid
  strategy     Strategy                   @relation(fields: [strategyId], references: [id])
  status       StrategySubscriptionStatus @default(active)
  subscribedAt DateTime                   @default(now()) @map("subscribed_at") @db.Timestamptz(6)
  cancelledAt  DateTime?                  @map("cancelled_at") @db.Timestamptz(6)
  createdAt    DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([userId, strategyId], map: "uniq_user_strategy_subscription")
  @@index([userId, status, subscribedAt(sort: Desc), id], map: "idx_user_strategy_subscriptions_user")
  @@index([strategyId, status], map: "idx_user_strategy_subscriptions_strategy")
  @@map("user_strategy_subscriptions")
}

model AdminAuditLog {
  id           String     @id @default(uuid()) @db.Uuid
  actorAdminId String?    @map("actor_admin_id") @db.Uuid
  actorAdmin   AdminUser? @relation("AdminAuditActor", fields: [actorAdminId], references: [id])
  action       String
  resourceType String     @map("resource_type")
  resourceId   String?    @map("resource_id") @db.Uuid
  strategyId   String?    @map("strategy_id") @db.Uuid
  strategy     Strategy?  @relation(fields: [strategyId], references: [id])
  reason       String
  before       Json?
  after        Json?
  ip           String?
  userAgent    String?    @map("user_agent")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([actorAdminId, createdAt(sort: Desc), id(sort: Desc)], map: "idx_admin_audit_actor")
  @@index([resourceType, resourceId, createdAt(sort: Desc), id(sort: Desc)], map: "idx_admin_audit_resource")
  @@map("admin_audit_logs")
}

model MembershipPlan {
  id              String                 @id @default(uuid()) @db.Uuid
  tier            MembershipTier         @unique
  name            String
  monthlyPriceCny Decimal                @map("monthly_price_cny") @db.Decimal(10, 2)
  yearlyPriceCny  Decimal                @map("yearly_price_cny") @db.Decimal(10, 2)
  displayOrder    Int                    @map("display_order")
  status          MembershipPlanStatus     @default(active)
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  entitlements    MembershipEntitlement[]
  subscriptions   UserSubscription[]

  @@map("membership_plans")
}

model MembershipEntitlement {
  id        String         @id @default(uuid()) @db.Uuid
  planId    String         @map("plan_id") @db.Uuid
  plan      MembershipPlan @relation(fields: [planId], references: [id])
  key       String
  valueType String         @map("value_type")
  value     String
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([planId, key], map: "uniq_membership_entitlements_plan_key")
  @@map("membership_entitlements")
}

model UserSubscription {
  id        String                 @id @default(uuid()) @db.Uuid
  userId    String                 @map("user_id") @db.Uuid
  user      User                   @relation(fields: [userId], references: [id])
  planId    String                 @map("plan_id") @db.Uuid
  plan      MembershipPlan         @relation(fields: [planId], references: [id])
  status    UserSubscriptionStatus @default(active)
  source    UserSubscriptionSource
  startsAt  DateTime               @map("starts_at") @db.Timestamptz(6)
  endsAt    DateTime               @map("ends_at") @db.Timestamptz(6)
  cancelledAt DateTime?            @map("cancelled_at") @db.Timestamptz(6)
  reason    String?
  createdAt DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([userId, status, endsAt(sort: Desc), id(sort: Desc)], map: "idx_user_subscriptions_user")
  @@map("user_subscriptions")
}

enum MarketSymbolStatus {
  active
  inactive

  @@map("market_symbol_status")
}

model MarketSymbol {
  id                String               @id @default(uuid()) @db.Uuid
  symbol            String               @unique
  baseAsset         String               @map("base_asset")
  quoteAsset        String               @map("quote_asset")
  status            MarketSymbolStatus   @default(active)
  pricePrecision    Int                  @default(2) @map("price_precision")
  quantityPrecision Int                  @default(8) @map("quantity_precision")
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  priceSnapshots    MarketPriceSnapshot[]

  @@map("market_symbols")
}

model MarketPriceSnapshot {
  id         String       @id @default(uuid()) @db.Uuid
  symbolId   String       @map("symbol_id") @db.Uuid
  symbol     MarketSymbol @relation(fields: [symbolId], references: [id])
  price      Decimal      @db.Decimal(28, 8)
  volume     Decimal?     @db.Decimal(28, 8)
  changeRate Decimal?     @map("change_rate") @db.Decimal(18, 8)
  source     String       @default("seed")
  capturedAt DateTime     @map("captured_at") @db.Timestamptz(6)
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([symbolId, capturedAt(sort: Desc)], map: "idx_market_price_snapshots_symbol_time")
  @@map("market_price_snapshots")
}

model PaperAccount {
  id                String             @id @default(uuid()) @db.Uuid
  userId            String             @map("user_id") @db.Uuid
  user              User               @relation(fields: [userId], references: [id])
  strategyId        String             @map("strategy_id") @db.Uuid
  strategy          Strategy           @relation(fields: [strategyId], references: [id])
  strategyVersionId String             @map("strategy_version_id") @db.Uuid
  strategyVersion   StrategyVersion    @relation(fields: [strategyVersionId], references: [id])
  symbol            String
  name              String
  initialBalance    Decimal            @map("initial_balance") @db.Decimal(28, 8)
  cashBalance       Decimal            @map("cash_balance") @db.Decimal(28, 8)
  currentEquity     Decimal            @map("current_equity") @db.Decimal(28, 8)
  peakEquity        Decimal            @map("peak_equity") @db.Decimal(28, 8)
  maxDrawdown       Decimal            @default(0) @map("max_drawdown") @db.Decimal(18, 8)
  maxPositionPct    Decimal            @map("max_position_pct") @db.Decimal(18, 8)
  maxPositions      Int                @map("max_positions")
  leverage          Int                @default(1)
  engineVersion     String             @default("paper-engine-v1") @map("engine_version")
  status            PaperAccountStatus @default(running)
  startedAt         DateTime           @default(now()) @map("started_at") @db.Timestamptz(6)
  pausedAt          DateTime?          @map("paused_at") @db.Timestamptz(6)
  endedAt           DateTime?          @map("ended_at") @db.Timestamptz(6)
  deletedAt         DateTime?          @map("deleted_at") @db.Timestamptz(6)
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  positions         PaperPosition[]
  orders            PaperOrder[]
  trades            PaperTrade[]
  performancePoints PaperPerformancePoint[]
  riskEvents        PaperRiskEvent[]

  @@index([userId, status, createdAt(sort: Desc), id(sort: Desc)], map: "idx_paper_accounts_user")
  @@map("paper_accounts")
}

model PaperPosition {
  id               String              @id @default(uuid()) @db.Uuid
  accountId        String              @map("account_id") @db.Uuid
  account          PaperAccount        @relation(fields: [accountId], references: [id])
  symbol           String
  side             PaperOrderSide      @default(buy)
  quantity         Decimal             @db.Decimal(28, 8)
  averagePrice     Decimal             @map("average_price") @db.Decimal(28, 8)
  markPrice        Decimal             @map("mark_price") @db.Decimal(28, 8)
  unrealizedPnl    Decimal             @map("unrealized_pnl") @db.Decimal(28, 8)
  status           PaperPositionStatus @default(open)
  openedAt         DateTime            @default(now()) @map("opened_at") @db.Timestamptz(6)
  closedAt         DateTime?           @map("closed_at") @db.Timestamptz(6)
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([accountId, status], map: "idx_paper_positions_account")
  @@map("paper_positions")
}

model PaperOrder {
  id             String           @id @default(uuid()) @db.Uuid
  accountId      String           @map("account_id") @db.Uuid
  account        PaperAccount     @relation(fields: [accountId], references: [id])
  signalId       String?          @map("signal_id") @db.Uuid
  signal         StrategySignal?  @relation(fields: [signalId], references: [id])
  side           PaperOrderSide
  type           PaperOrderType   @default(market)
  price          Decimal?         @db.Decimal(28, 8)
  quantity       Decimal          @db.Decimal(28, 8)
  status         PaperOrderStatus @default(pending)
  rejectReason   String?          @map("reject_reason")
  engineSnapshot Json?            @map("engine_snapshot")
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  trade          PaperTrade?

  @@index([accountId, createdAt(sort: Desc), id(sort: Desc)], map: "idx_paper_orders_account")
  @@map("paper_orders")
}

model PaperTrade {
  id               String       @id @default(uuid()) @db.Uuid
  accountId        String       @map("account_id") @db.Uuid
  account          PaperAccount @relation(fields: [accountId], references: [id])
  orderId          String       @unique @map("order_id") @db.Uuid
  order            PaperOrder   @relation(fields: [orderId], references: [id])
  price            Decimal      @db.Decimal(28, 8)
  quantity         Decimal      @db.Decimal(28, 8)
  fee              Decimal      @db.Decimal(28, 8)
  realizedPnl      Decimal      @default(0) @map("realized_pnl") @db.Decimal(28, 8)
  executedAt       DateTime     @default(now()) @map("executed_at") @db.Timestamptz(6)
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([accountId, executedAt(sort: Desc), id(sort: Desc)], map: "idx_paper_trades_account")
  @@map("paper_trades")
}

model PaperPerformancePoint {
  id             String       @id @default(uuid()) @db.Uuid
  accountId      String       @map("account_id") @db.Uuid
  account        PaperAccount @relation(fields: [accountId], references: [id])
  equity         Decimal      @db.Decimal(28, 8)
  returnRate     Decimal      @map("return_rate") @db.Decimal(18, 8)
  drawdown       Decimal      @db.Decimal(18, 8)
  positionCount  Int          @map("position_count")
  recordedAt     DateTime     @default(now()) @map("recorded_at") @db.Timestamptz(6)

  @@unique([accountId, recordedAt], map: "uniq_paper_performance_points_account_time")
  @@index([accountId, recordedAt(sort: Desc)], map: "idx_paper_performance_points_account")
  @@map("paper_performance_points")
}

model PaperRiskEvent {
  id         String       @id @default(uuid()) @db.Uuid
  accountId  String       @map("account_id") @db.Uuid
  account    PaperAccount @relation(fields: [accountId], references: [id])
  type       String
  riskLevel  RiskLevel    @map("risk_level")
  message    String
  payload    Json?
  occurredAt DateTime     @default(now()) @map("occurred_at") @db.Timestamptz(6)

  @@index([accountId, occurredAt(sort: Desc), id(sort: Desc)], map: "idx_paper_risk_events_account")
  @@map("paper_risk_events")
}
